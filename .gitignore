# Raw input data (third-party, not redistributed)
data/raw/

# Large intermediate files
data/processed/*.fa
data/processed/*.fasta

# Python cache
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/

# Conda env (referenced, not stored)
envs/*.yml.bak

# Editor
.vscode/
*.swp

# Large derived data files (regenerate with pipeline)
data/processed/sequences/*.fa
data/processed/sequences/*.gtf
data/processed/bioemu/*/samples.xtc
data/processed/bioemu/*/topology.pdb
data/processed/bioemu/*_dp.ps

# Keep: CSVs, manifests, logs, input FASTAs

# RNAfold dot-plot postscript files
*.ps
*.eps

# BioEmu conformational ensembles (large binaries)
data/processed/bioemu/AT*/

# AF2 structure cache
data/processed/af2_cache/

# UMAP embedding cache (regenerable)
data/processed/umap_cache.npz

# Backup files
data/processed/*.pre_*

# nohup logs
logs/*_nohup.log
.snakemake/

# MLflow run artifacts (regenerable by running 10b_mlflow_retroactive.py)
mlruns/
.coverage
htmlcov/

# EvidentlyAI reports (regenerable by running scripts/10c_evidently_report.py)
# Keep the .gitkeep placeholder; exclude generated HTMLs
monitoring/evidently_reports/*.html
monitoring/evidently_reports/*.json

# ChromaDB vector store (regenerable by running agent/ingest.py)
agent/chroma_db/
data/papers/*.pdf
