# Raw input data (third-party, not redistributed)
data/raw/

# Large intermediate files
data/processed/*.fa
data/processed/*.fasta

# Python cache
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/

# Conda env (referenced, not stored)
envs/*.yml.bak

# Editor
.vscode/
*.swp

# Large derived data files (regenerate with pipeline)
data/processed/sequences/*.fa
data/processed/sequences/*.gtf
data/processed/bioemu/*/samples.xtc
data/processed/bioemu/*/topology.pdb
data/processed/bioemu/*_dp.ps

# Keep: CSVs, manifests, logs, input FASTAs
